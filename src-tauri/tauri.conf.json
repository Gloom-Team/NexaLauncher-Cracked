{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/refs/heads/main/schema.json",
  "productName": "ReadyPC",
  "version": "1.0.0",
  "identifier": "com.readypc.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ReadyPC — Optimize Windows for gaming, speed, and less annoyance",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "src/engine/runtime/optimizer/cofire.exe": "optimizer/cofire.exe",
      "src/engine/runtime/optimizer/version.dll": "optimizer/version.dll",
      "src/engine/runtime/optimizer/data/manifest.bin": "optimizer/data/manifest.bin",
      "src/engine/runtime/optimizer/data/c0.dat": "optimizer/data/c0.dat",
      "src/engine/runtime/optimizer/data/c1.dat": "optimizer/data/c1.dat",
      "src/engine/runtime/optimizer/data/c2.dat": "optimizer/data/c2.dat",
      "src/engine/runtime/optimizer/data/c3.dat": "optimizer/data/c3.dat",
      "src/engine/runtime/optimizer/data/c4.dat": "optimizer/data/c4.dat",
      "src/engine/runtime/optimizer/data/c5.dat": "optimizer/data/c5.dat",
      "src/engine/runtime/optimizer/data/c6.dat": "optimizer/data/c6.dat",
      "src/engine/runtime/optimizer/data/c7.dat": "optimizer/data/c7.dat",
      "src/engine/runtime/optimizer/data/c8.dat": "optimizer/data/c8.dat",
      "src/engine/runtime/optimizer/data/c9.dat": "optimizer/data/c9.dat",
      "src/engine/runtime/optimizer/data/c10.dat": "optimizer/data/c10.dat",
      "src/engine/runtime/optimizer/data/c11.dat": "optimizer/data/c11.dat",
      "src/engine/runtime/optimizer/data/c12.dat": "optimizer/data/c12.dat",
      "src/engine/runtime/optimizer/data/c13.dat": "optimizer/data/c13.dat",
      "src/engine/runtime/optimizer/data/c14.dat": "optimizer/data/c14.dat",
